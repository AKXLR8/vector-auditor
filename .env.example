# ── Required ────────────────────────────────────────────────────────
LLM_API_KEY=
JWT_SECRET_KEY=

# ── LLM provider (defaults to api.inceptionlabs.ai/v1) ──────────────
LLM_BASE_URL=https://api.inceptionlabs.ai/v1
LLM_MODEL=mercury-2

# ── Environment ─────────────────────────────────────────────────────
ENVIRONMENT=production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_FORMAT=json
LOG_LEVEL=INFO

# ── Optional — PostgreSQL ──────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# ── Optional — Qdrant Cloud ────────────────────────────────────────
# QDRANT_URL=https://xxx.cloud.qdrant.io:6333
# QDRANT_API_KEY=

# ── Optional — Redis ───────────────────────────────────────────────
# REDIS_URL=rediss://default:pass@host:6379

# ── Optional — Cloudinary (PDF serving) ────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Optional — PII detection (enabled ≈ +500 MB image) ────────────
# PII_ENABLED=false

# ── Performance ────────────────────────────────────────────────────
JOB_MAX_CONCURRENT=5
RETRIEVE_K_PER_QUERY=10
MAX_CITATIONS_PER_DOC=6
MAX_CITATIONS_TOTAL=20
MAX_DOCUMENT_HOPS=3
